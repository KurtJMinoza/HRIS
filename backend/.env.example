APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Match how you open the API in the browser (Laragon virtual host or php artisan serve).
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Laragon MySQL (typical): start MySQL in Laragon, create database (e.g. hris), then use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hris
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# For Sanctum SPA cookie auth across subdomains, set e.g. .yourdomain.com (leading dot). Local dev: leave null.
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = no extra infra; redis = recommended for production (faster, fewer stuck jobs).
QUEUE_CONNECTION=database
# Seconds before a reserved job is released back to the queue — must be > worker --timeout and > longest job (face registration job = 60s).
DB_QUEUE_RETRY_AFTER=120
REDIS_QUEUE_RETRY_AFTER=120
#
# Face registration is queued to `face-registration` (see ProcessFaceRegistrationJob). You MUST run a worker that listens on that queue.
# Local (second terminal), database driver:
#   php artisan queue:work database --queue=face-registration,default --timeout=90
# Local / production with Redis (QUEUE_CONNECTION=redis):
#   php artisan queue:work redis --queue=face-registration,default --timeout=90
# Production: use Supervisor or Laravel Horizon to keep the worker running (see deployment/supervisor-face-registration.conf.example).
#
# Other long-running jobs (payroll finalize, profile cache): same worker or a separate process with a higher --timeout if needed.

CACHE_STORE=database
# Employee profile + Auth /user JSON: store name from config/cache.php `stores` (e.g. array, database, redis).
# Use `array` on Windows (local Laragon/php artisan serve) to avoid slow file-cache writes (storage/framework/cache). No cross-request persistence.
# Use `database` (with cache table migrated) or `redis` in production for persistent profile caching.
CACHE_PROFILE_STORE=array
CACHE_PROFILE_TTL_MINUTES=5
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (S3, Rekognition Face Liveness). Rekognition uses key/secret/region below.
# For Face Liveness: IAM user/role needs rekognition:CreateFaceLivenessSession and rekognition:GetFaceLivenessSessionResults.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum SPA: hosts that receive session + CSRF (no protocol). Must include your Vite dev origin.
# If CSRF mismatch on POST /api/*, verify this list matches the browser address bar (host:port).
# Laragon .test sites: add e.g. hr.test:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:3000,127.0.0.1:3000
SANCTUM_TOKEN_EXPIRATION=10080

# When true, each login revokes all other Sanctum tokens for that user (one active session).
# When false (default), multiple tabs/devices can stay signed in with separate tokens.
AUTH_SINGLE_SESSION=false

# CORS: comma-separated frontend origins (required when using credentials)
# Laragon: include http://hr.test:5173 (or your site name) if Vite runs on that host.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# In local/testing, config/cors.php also allows any port on localhost / 127.0.0.1 via allowed_origins_patterns.

# Whether employee phone_number is required (true) or optional (false)
EMPLOYEE_PHONE_REQUIRED=true

# SMS notifications (Philippine mobile, PhilSMS v3). Queued; run: php artisan queue:work
PHILSMS_BASE_URL=https://dashboard.philsms.com/api/v3
PHILSMS_API_TOKEN=  
PHILSMS_SENDER_ID=PhilSMS

# Optional: comma-separated holidays (YYYY-MM-DD). QR attendance is blocked on these dates.
# ATTENDANCE_HOLIDAYS=2026-01-01,2026-04-09

# Late OT filing: max calendar days after the work date (past dates need clock-in + clock-out that day).
# OVERTIME_FILING_WINDOW_DAYS=7
# Minutes after approved OT "expected end" that clock-out is still allowed (actual time-out is never overridden).
# OVERTIME_APPROVED_CLOCKOUT_GRACE_MINUTES=30
# Generic cap after shift end when there is no approved OT extending the window.
# ATTENDANCE_LATEST_CLOCKOUT_AFTER_MINUTES=60

# Time and Date Holidays API (Philippines). Get keys from https://dev.timeanddate.com/account/accesskey
# TIMEDATE_ACCESS_KEY=your_access_key
# TIMEDATE_SECRET_KEY=your_secret_key

# Calendarific Holidays API (Admin Calendar). Get key from https://calendarific.com/
# CALENDARIFIC_API_KEY=your_api_key

# Face verification: Python FastAPI service (InsightFace ArcFace, 512D embeddings).
# Liveness = Amazon Rekognition Face Liveness. This service only extracts embeddings.
#
# Setup (first time only — downloads buffalo_l model ~300 MB):
#   cd face_service
#   pip install -r requirements.txt
#   uvicorn main:app --host 0.0.0.0 --port 5000
#
# Optional Python service env vars (set before starting uvicorn):
#   INSIGHTFACE_MODEL=buffalo_l          (default buffalo_l; buffalo_s is faster but less accurate)
#   INSIGHTFACE_DET_SIZE=640,640         (detection input size)
#   ONNX_PROVIDERS=CPUExecutionProvider  (GPU: CUDAExecutionProvider,CPUExecutionProvider)
FACE_VERIFICATION_URL=http://127.0.0.1:5000

# Amazon Rekognition Face Liveness: backend creates sessions via AWS_* above.
# Face Liveness ONLY in us-east-1, us-east-2. Other regions = AccessDeniedException.
# REKOGNITION_REGION=us-east-1
# Verify: php artisan rekognition:check
# Optional: ATTENDANCE_FACE_MIN_LIVENESS_SCORE (default 0.52). Lower = fewer false rejects; 0.65+ stricter.
# Optional: ATTENDANCE_FACE_CLOCK_MIN_LIVENESS_SCORE (default 0.60). Stronger floor for clock in/out verification.
# Cognito Identity Pool: required for Amplify FaceLivenessDetector (frontend signs Rekognition requests).
# IMPORTANT: Identity Pool must be in the SAME region as Rekognition (us-east-1). Enable unauthenticated access.
# IAM unauth role must allow: rekognition:StartFaceLivenessSession
# COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COGNITO_REGION=us-east-1

# Face login: thresholds for InsightFace ArcFace 512D L2-normalized embeddings.
# InsightFace same-person cosine similarity ≈ 0.3–0.7 (lighting/pose varies); different-person < 0.25.
#
# Cosine distance: match when cosine_distance <= value (primary mode). 0.55 ≈ similarity ≥ 0.45.
# ATTENDANCE_FACE_COSINE_DISTANCE_THRESHOLD=0.55
#
# Euclidean distance (fallback, used only when cosine threshold is unset/null).
# InsightFace unit vectors: cos_sim=0.45 → euc≈1.05; cos_sim=0.5 → euc≈1.0.
# ATTENDANCE_FACE_MATCH_THRESHOLD=1.10
#
# Additional anti-misidentification checks:
# - require minimum cosine similarity (InsightFace ArcFace: 0.40 is reliable for same person)
# - require a margin vs the runner-up candidate (reject ambiguous matches)
# ATTENDANCE_FACE_MIN_SIMILARITY_SCORE=0.40
# ATTENDANCE_FACE_MIN_SIMILARITY_MARGIN=0.04
#
# Kiosk clock-in/out: looser thresholds (liveness already proven by Rekognition).
# Set to empty/unset to fall back to the general thresholds above.
# ATTENDANCE_FACE_KIOSK_COSINE_DISTANCE_THRESHOLD=0.62
# ATTENDANCE_FACE_KIOSK_MIN_SIMILARITY_SCORE=0.35
# ATTENDANCE_FACE_KIOSK_MATCH_THRESHOLD=1.20
# If claimed user mismatch is detected and another user matches above this score,
# return explicit `face_account_mismatch`.
# ATTENDANCE_FACE_KIOSK_ACCOUNT_MISMATCH_MIN_SIMILARITY=0.60
#
# Cross-camera accuracy mode (registration camera A, kiosk camera B):
# If liveness confidence is very high, apply a small threshold relaxation to reduce
# false rejects caused by camera differences (sensor, lens, white balance, compression),
# while still requiring a stronger winner-vs-runner-up margin to avoid misidentification.
# ATTENDANCE_FACE_CROSS_CAMERA_RELAX_ENABLED=true
# ATTENDANCE_FACE_CROSS_CAMERA_HIGH_LIVENESS=0.90
# ATTENDANCE_FACE_CROSS_CAMERA_MIN_SIM_RELAX_DELTA=0.05
# ATTENDANCE_FACE_CROSS_CAMERA_COS_DIST_RELAX_DELTA=0.04
# ATTENDANCE_FACE_CROSS_CAMERA_MIN_SIM_FLOOR=0.33
# ATTENDANCE_FACE_CROSS_CAMERA_MIN_MARGIN=0.06

# Duplicate-face check (registration): prevent same face on multiple accounts.
# InsightFace ArcFace: cosine similarity ≥ 0.70 reliably means same person.
# Multi-signal: cosine (normalized + raw), Euclidean, dual-signal band, aggregate best-of-samples.
# Primary per-row cosine gate (floor-enforced to min ATTENDANCE_FACE_DUPLICATE_REGISTRATION_COSINE_FLOOR):
# ATTENDANCE_FACE_DUPLICATE_MIN_COSINE_SIM=0.60
# Euclidean distance on InsightFace 512-D unit vectors (cos_sim=0.70 → euc≈0.77):
# ATTENDANCE_FACE_DUPLICATE_MAX_EUCLIDEAN=0.80
# Normalized Euclidean distance (same value since vectors are already L2-normalized):
# ATTENDANCE_FACE_DUPLICATE_MAX_EUCLIDEAN_NORM=0.80
# Cosine floor enforcement (prevents misconfigured env from weakening detection):
# ATTENDANCE_FACE_DUPLICATE_ENFORCE_COSINE_FLOOR=true
# ATTENDANCE_FACE_DUPLICATE_REGISTRATION_COSINE_FLOOR=0.60
# Dual-signal band (catches borderline same-person pairs):
# ATTENDANCE_FACE_DUPLICATE_DUAL_SIGNAL=true
# ATTENDANCE_FACE_DUPLICATE_DUAL_COSINE_MIN=0.60
# ATTENDANCE_FACE_DUPLICATE_DUAL_MAX_EUCLIDEAN=0.85
# Aggregate best-of-all-samples (max similarity across all stored vectors for one user):
# ATTENDANCE_FACE_DUPLICATE_AGGREGATE_BEST_COSINE_MIN=0.60
# Raw (un-normalized) cosine similarity (InsightFace vectors are already normalized; same as primary):
# ATTENDANCE_FACE_DUPLICATE_RAW_COSINE_MIN=0.60
# Full DB scan on registration (recommended true):
# ATTENDANCE_FACE_DUPLICATE_REGISTRATION_FULL_SCAN=true
# ── Strict global uniqueness gate (ProcessFaceRegistrationJob) ─────────────────
# This gate runs once per registration, ALWAYS scanning the live DB (never cache).
# Blocks when: cosine(normalised_a, normalised_b) >= STRICT_COSINE
#           OR  euclidean(normalised_a, normalised_b) <= STRICT_EUCLIDEAN_NORM
# For InsightFace ArcFace unit vectors:
#   cos=0.88 → norm-euc=0.490 (strict)
#   norm-euc=0.35 → cos≈0.939 (very strict, lower false negatives are sacrificed for stronger duplicate blocking)
# Raise STRICT_COSINE to reduce false positives (same face blocked ↓).
# Lower  STRICT_COSINE to catch more borderline same-person pairs (aggression ↑).
# ATTENDANCE_FACE_DUPLICATE_STRICT_COSINE=0.88
# ATTENDANCE_FACE_DUPLICATE_STRICT_EUCLIDEAN_NORM=0.35
# Near-miss logging band: log comparisons in [NEAR_MISS, STRICT_COSINE) for tuning.
# ATTENDANCE_FACE_DUPLICATE_STRICT_NEAR_MISS=0.72

# When true, payroll lock checks clear finalized payslips / locked periods if no matching finalized payroll_batch_runs row exists (recovery after bad deletes).
# PAYROLL_AUTO_RECONCILE_ORPHAN_LOCKS=true

# Leave credits: shared paid-leave pool (default 7). Annual recharge on January 1 (see LeaveCreditService).
# LEAVE_ANNUAL_CREDITS=7
# Set true to reset credits to annual allocation when HR approves contract renewal (otherwise credits carry over until Jan 1).
# LEAVE_RESET_ON_CONTRACT_RENEWAL=false
