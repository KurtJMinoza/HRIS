APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Match how you open the API in the browser (Laragon virtual host or php artisan serve).
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Laragon MySQL (typical): start MySQL in Laragon, create database (e.g. hris), then use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hris
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# For Sanctum SPA cookie auth across subdomains, set e.g. .yourdomain.com (leading dot). Local dev: leave null.
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Long-running jobs (finalize payroll, profile cache, compensation warm): run in another terminal:
#   php artisan queue:work database --queue=default --timeout=0
# Raise DB_QUEUE_RETRY_AFTER (seconds) above your longest job timeout so work is not duplicated (see config/queue.php).

CACHE_STORE=database
# Employee profile + Auth /user JSON: store name from config/cache.php `stores` (e.g. array, database, redis).
# Use `array` on Windows (local Laragon/php artisan serve) to avoid slow file-cache writes (storage/framework/cache). No cross-request persistence.
# Use `database` (with cache table migrated) or `redis` in production for persistent profile caching.
CACHE_PROFILE_STORE=array
CACHE_PROFILE_TTL_MINUTES=5
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (S3, Rekognition Face Liveness). Rekognition uses key/secret/region below.
# For Face Liveness: IAM user/role needs rekognition:CreateFaceLivenessSession and rekognition:GetFaceLivenessSessionResults.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum SPA: hosts that receive session + CSRF (no protocol). Must include your Vite dev origin.
# If CSRF mismatch on POST /api/*, verify this list matches the browser address bar (host:port).
# Laragon .test sites: add e.g. hr.test:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:3000,127.0.0.1:3000
SANCTUM_TOKEN_EXPIRATION=10080

# When true, each login revokes all other Sanctum tokens for that user (one active session).
# When false (default), multiple tabs/devices can stay signed in with separate tokens.
AUTH_SINGLE_SESSION=false

# CORS: comma-separated frontend origins (required when using credentials)
# Laragon: include http://hr.test:5173 (or your site name) if Vite runs on that host.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# In local/testing, config/cors.php also allows any port on localhost / 127.0.0.1 via allowed_origins_patterns.

# Whether employee phone_number is required (true) or optional (false)
EMPLOYEE_PHONE_REQUIRED=true

# SMS notifications (Philippine mobile, PhilSMS v3). Queued; run: php artisan queue:work
PHILSMS_BASE_URL=https://dashboard.philsms.com/api/v3
PHILSMS_API_TOKEN=  
PHILSMS_SENDER_ID=PhilSMS

# Optional: comma-separated holidays (YYYY-MM-DD). QR attendance is blocked on these dates.
# ATTENDANCE_HOLIDAYS=2026-01-01,2026-04-09

# Late OT filing: max calendar days after the work date (past dates need clock-in + clock-out that day).
# OVERTIME_FILING_WINDOW_DAYS=7
# Minutes after approved OT "expected end" that clock-out is still allowed (actual time-out is never overridden).
# OVERTIME_APPROVED_CLOCKOUT_GRACE_MINUTES=30
# Generic cap after shift end when there is no approved OT extending the window.
# ATTENDANCE_LATEST_CLOCKOUT_AFTER_MINUTES=60

# Time and Date Holidays API (Philippines). Get keys from https://dev.timeanddate.com/account/accesskey
# TIMEDATE_ACCESS_KEY=your_access_key
# TIMEDATE_SECRET_KEY=your_secret_key

# Calendarific Holidays API (Admin Calendar). Get key from https://calendarific.com/
# CALENDARIFIC_API_KEY=your_api_key

# Face verification: Python FastAPI (embedding only). Liveness = Amazon Rekognition Face Liveness.
# Run: uvicorn main:app --port 5000 (in face_service/)
FACE_VERIFICATION_URL=http://127.0.0.1:5000
# DeepFace performance tuning (Python service must support these option fields).
FACE_VERIFICATION_MODEL_NAME=ArcFace
FACE_VERIFICATION_DETECTOR_BACKEND=mediapipe
FACE_VERIFICATION_ENFORCE_DETECTION=true
FACE_VERIFICATION_ALIGN=true
FACE_VERIFICATION_INPUT_WIDTH=640
FACE_VERIFICATION_INPUT_HEIGHT=480

# Amazon Rekognition Face Liveness: backend creates sessions via AWS_* above.
# Face Liveness ONLY in us-east-1, us-east-2. Other regions = AccessDeniedException.
# REKOGNITION_REGION=us-east-1
# Verify: php artisan rekognition:check
# Optional: ATTENDANCE_FACE_MIN_LIVENESS_SCORE (default 0.52). Lower = fewer false rejects; 0.65+ stricter.
# Cognito Identity Pool: required for Amplify FaceLivenessDetector (frontend signs Rekognition requests).
# IMPORTANT: Identity Pool must be in the SAME region as Rekognition (us-east-1). Enable unauthenticated access.
# IAM unauth role must allow: rekognition:StartFaceLivenessSession
# COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COGNITO_REGION=us-east-1

# Face login: thresholds (stricter = fewer false matches, more rejections).
# Euclidean distance: match when distance <= value. Facenet same-person often 0.5–1.0.
# ATTENDANCE_FACE_MATCH_THRESHOLD=0.78
#
# Cosine distance: match when cosine_distance <= value. 0.2 ~= cosine similarity >= 0.8.
# ATTENDANCE_FACE_COSINE_DISTANCE_THRESHOLD=0.35
#
# Additional anti-misidentification checks:
# - require minimum cosine similarity
# - require a margin vs the runner-up candidate (reject ambiguous matches)
# ATTENDANCE_FACE_MIN_SIMILARITY_SCORE=0.65
# ATTENDANCE_FACE_MIN_SIMILARITY_MARGIN=0.04

# Duplicate-face check (registration): stricter than match threshold to avoid false "already registered".
# Only used when checking if a new face is already on another account. Defaults: 0.5 (Euclidean), 0.25 (cosine distance).
# Duplicate enrollment: primary gate = max cosine similarity vs any stored vector >= ATTENDANCE_FACE_DUPLICATE_MIN_BEST_SIM (default 0.50).
# Fallback: per-row cosine distance thresholds (COSINE_THRESHOLD / COSINE_AVG_THRESHOLD).
# ATTENDANCE_FACE_DUPLICATE_MATCH_THRESHOLD=0.62
# ATTENDANCE_FACE_DUPLICATE_COSINE_THRESHOLD=0.45
# ATTENDANCE_FACE_DUPLICATE_COSINE_AVG_THRESHOLD=0.52
# ATTENDANCE_FACE_DUPLICATE_MIN_BEST_SIM=0.50

# When true, payroll lock checks clear finalized payslips / locked periods if no matching finalized payroll_batch_runs row exists (recovery after bad deletes).
# PAYROLL_AUTO_RECONCILE_ORPHAN_LOCKS=true

# Leave credits: shared paid-leave pool (default 7). Annual recharge on January 1 (see LeaveCreditService).
# LEAVE_ANNUAL_CREDITS=7
# Set true to reset credits to annual allocation when HR approves contract renewal (otherwise credits carry over until Jan 1).
# LEAVE_RESET_ON_CONTRACT_RENEWAL=false
