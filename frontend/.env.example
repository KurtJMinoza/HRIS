# Copy to .env and adjust for your environment.

# If the production build is served from a subpath (e.g. http://localhost/HR/ or Laragon alias),
# set this so JS/CSS load correctly and routes match. Include leading and trailing slash.
# VITE_BASE=/HR/

# When the API is not at the Vite default proxy (127.0.0.1:8000), set the Laravel base URL:
# VITE_DEV_API_PROXY_TARGET=http://hr.test

# API base URL (see src/api.js). Production default is http://localhost:8000/api if unset.
# VITE_API_URL=http://127.0.0.1:8000/api
